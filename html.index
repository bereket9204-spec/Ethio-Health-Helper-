<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EthioHealth | The Truth About Your Body</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body>

<div class="glass-container">
  <header class="health-header">
    <div class="health-icon">🔬</div>
    <h1 id="ui-title">Stop Guessing. Start Knowing.</h1>
    <p id="ui-subtitle">Paste that confusing medical term below. We'll turn it into human language.</p>
  </header>

  <div class="mode-toggle">
    <button id="toggleStudy" onclick="toggleMode()">🔥 The 5 Lethal Health Myths</button>
  </div>

  <main id="scannerSection" class="input-area">
    <textarea id="userInput" placeholder="Type Hypertension, BID, or any lab result here..."></textarea>
    <button id="analyzeBtn">Decode the Truth</button>
    <div id="resultContainer" class="hidden">
      <div class="result-card">
        <h3 id="ui-result-title">🩺 The Simple Truth:</h3>
        <div id="aiResponse"></div>
        <p class="disclaimer">⚠️ AI is a tool, not a doctor. Verify everything.</p>
      </div>
    </div>
  </main>

  <section id="studySection" class="hidden">
    <div class="course-slide">
      <h2 id="course-title">Master Your Health</h2>
      <div class="progress-bar"><div class="progress" id="ui-progress"></div></div>
      <div id="course-content" class="course-text"></div>
      <div class="course-nav">
        <button class="nav-btn" onclick="prevLesson()">←</button>
        <button class="nav-btn primary-btn" onclick="nextLesson()">→</button>
      </div>
    </div>
  </section>
</div>

<div class="bottom-nav">
  <button class="lang-btn active" id="btn-en" onclick="setLanguage('en')">EN</button>
  <button class="lang-btn" id="btn-am" onclick="setLanguage('am')">አማ</button>
  <button class="lang-btn" id="btn-om" onclick="setLanguage('om')">ORM</button>
</div>

<script src="script.js"></script>
</body>
</html>
